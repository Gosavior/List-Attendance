# ============================================
# STAFF PORTAL - Environment Configuration
# Template untuk Development Environment
# ============================================

# Database Configuration
DB_HOST=localhost
DB_NAME=arth_staff_dev
DB_USERNAME=your_database_username
DB_PASSWORD=your_database_password

# JWT Secret (Generate random string untuk production)
JWT_SECRET=your_jwt_secret_key_here_min_32_characters

# Application Settings
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/staff.arthasolusiaditama.com

# Session Configuration
SESSION_LIFETIME=120
SESSION_SECURE=false

# Upload Settings
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,xlsx

# Socket.IO Server (Chat)
SOCKET_PORT=3000
SOCKET_HOST=localhost

# Timezone
APP_TIMEZONE=Asia/Jakarta

# ============================================
# INSTRUKSI SETUP:
# ============================================
# 1. Copy file ini menjadi .env
# 2. Ganti semua nilai dengan credentials Anda
# 3. JANGAN commit file .env ke Git
# 4. Untuk production, set APP_ENV=production dan APP_DEBUG=false
# ============================================
