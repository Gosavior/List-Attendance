# ============================================
# SALES SYSTEM BACKEND - Environment Configuration
# Template untuk Development Environment
# ============================================

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration (Generate random string untuk production)
JWT_SECRET=your_jwt_secret_key_here_min_32_characters
JWT_EXPIRES_IN=8h

# ============================================
# Database: Staff (untuk autentikasi user)
# ============================================
DB_STAFF_HOST=localhost
DB_STAFF_PORT=3306
DB_STAFF_NAME=arth_staff_dev
DB_STAFF_USER=your_database_username
DB_STAFF_PASS=your_database_password

# ============================================
# Database: Sales (untuk data project, RAB, dll)
# ============================================
DB_SALES_HOST=localhost
DB_SALES_PORT=3306
DB_SALES_NAME=asasystem_sales_dev
DB_SALES_USER=your_database_username
DB_SALES_PASS=your_database_password

# Frontend URL (untuk CORS)
FRONTEND_URL=http://localhost:5173

# Upload Configuration
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=10485760

# API Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# INSTRUKSI SETUP:
# ============================================
# 1. Copy file ini menjadi .env
# 2. Ganti semua nilai dengan credentials Anda
# 3. Generate JWT_SECRET dengan: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 4. JANGAN commit file .env ke Git
# 5. Untuk production, set NODE_ENV=production
# ============================================
