# ============================================
# SALES SYSTEM FRONTEND - Environment Configuration
# Template untuk Development Environment
# ============================================

# API Backend URL
VITE_API_URL=http://localhost:5000/api

# Application Settings
VITE_APP_NAME=ASA Sales System
VITE_APP_ENV=development

# Upload Settings
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf

# ============================================
# INSTRUKSI SETUP:
# ============================================
# 1. Copy file ini menjadi .env.development
# 2. Sesuaikan VITE_API_URL dengan backend URL Anda
# 3. JANGAN commit file .env.development ke Git
# ============================================
